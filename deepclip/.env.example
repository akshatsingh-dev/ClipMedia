# Copy this to .env and fill in real values. .env is gitignored — never commit it.

# --- LLM provider ---
# The project defaults to Gemini when GEMINI_API_KEY is present.
# Get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Optional: force a provider. Leave blank to auto-detect from whichever key is set.
#   gemini | anthropic
LLM_PROVIDER=gemini

# Optional: override the Gemini model per tier (names change over time).
# GEMINI_MODEL_FAST=gemini-2.5-flash
# GEMINI_MODEL_SMART=gemini-2.5-pro

# Only needed if LLM_PROVIDER=anthropic
# ANTHROPIC_API_KEY=

# --- YouTube Data API v3 ---
# Google Cloud console -> enable "YouTube Data API v3" -> create an API key
YOUTUBE_API_KEY=

# --- infra (defaults match docker-compose; override only if running services elsewhere) ---
DATABASE_URL=postgresql://deepclip:deepclip@localhost:5432/deepclip
REDIS_URL=redis://localhost:6379
